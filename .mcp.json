{
  "mcpServers": {
    "astro-docs": {
      "type": "http",
      "url": "https://mcp.docs.astro.build/mcp"
    },
    "zod-v4-docs": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.inkeep.com/zod/mcp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    },
    "daisyui": {
      "type": "http",
      "url": "https://gitmcp.io/saadeghi/daisyui"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    }
  }
}
